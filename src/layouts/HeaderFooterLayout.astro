---
import Header from "@/components/Header.astro";
import Footer from '@/components/Footer.astro'
const { gradientBackground } = Astro.props
---
<div class="gradient" transition:name="background" transition:persist></div>
<div class="layout">
  <Header></Header>
  <main>
    <slot></slot>
  </main>
  <Footer></Footer>
</div>

<style>
  .gradient {
    position: fixed;
    inset: 0;
    z-index: -50;
    background: url("/background-blured.webp") center/cover no-repeat;
  }
  .layout {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    z-index: 0;
  }
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
</style>
