---
import 'photoswipe/style.css'

import galleryCategories, {
  getGalleryCoverPreviewURL,
  getGalleryCoverURL,
  getGalleryImageURL,
  getGalleryPreviewURL,
} from '@/data/gallery'
import { galleryImageSizes } from '@/data/gallery-sizes.generated'
import HeaderFooterLayout from '@/layouts/HeaderFooterLayout.astro'
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'Gallery'
const pageDescription = '收集到的图'
const imageFallbackHandler = "this.onerror=null;const fallback=this.dataset.fallbackSrc;if(fallback&&this.src!==fallback){this.src=fallback;this.removeAttribute('data-fallback-src')}"
const galleryImageSizeMap = galleryImageSizes as Record<string, { width: number; height: number } | undefined>

const getFileName = (path: string) => {
  const cleanPath = path.split(/[?#]/)[0] ?? path
  return cleanPath.split('/').filter(Boolean).at(-1) ?? path
}

const getDisplayName = (path: string) => getFileName(path).replace(/\.[^.]+$/, '')

const categories = galleryCategories.map((category, categoryIndex) => {
  const id = `gallery-category-${categoryIndex + 1}`
  const coverURL = getGalleryCoverURL(category)
  const coverPreviewURL = getGalleryCoverPreviewURL(category)
  const images = category.images.map((image, imageIndex) => {
    const url = getGalleryImageURL(category, image)
    const previewURL = getGalleryPreviewURL(category, image)
    const generatedSize = galleryImageSizeMap[url]
    const width = image.width ?? generatedSize?.width
    const height = image.height ?? generatedSize?.height
    const name = image.name ?? getDisplayName(image.src)

    return {
      ...image,
      url,
      previewURL,
      width,
      height,
      name,
      alt: image.description ? `${name} - ${image.description}` : name,
      index: imageIndex,
      hasOriginalSize: Boolean(width && height),
    }
  })

  return {
    ...category,
    id,
    coverURL,
    coverPreviewURL,
    images,
    imageCount: images.length,
  }
})

const totalImageCount = categories.reduce((total, category) => total + category.imageCount, 0)
const firstCoverURL = categories.find((category) => category.coverURL)?.coverURL
---

<Layout title={pageTitle} description={pageDescription} image={firstCoverURL}>
  <HeaderFooterLayout>
    <div class="gallery-page">
      <section class="hero" aria-labelledby="gallery-title">
        <div class="hero-copy">
          <div class="eyebrow">Gallery</div>
          <h1 id="gallery-title">Gallery</h1>
          <p>
            按分类整理收藏图片。当前收录 {categories.length} 个分类，{totalImageCount} 张图片。
          </p>
        </div>

        <div class="hero-covers" aria-hidden="true">
          {categories.slice(0, 3).map((category, index) => (
            category.coverURL && (
              <img
                class={`hero-cover hero-cover-${index + 1}`}
                src={category.coverPreviewURL}
                data-fallback-src={category.coverURL}
                onerror={imageFallbackHandler}
                alt=""
                loading={index === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            )
          ))}
        </div>
      </section>

      <nav class="category-nav" aria-label="Gallery 分类">
        {categories.map((category) => (
          <a class="category-link" href={`#${category.id}`}>
            {category.coverURL && (
              <img
                src={category.coverPreviewURL}
                data-fallback-src={category.coverURL}
                onerror={imageFallbackHandler}
                alt=""
                loading="lazy"
                decoding="async"
              />
            )}
            <span>
              <strong>{category.name}</strong>
              <small>{category.imageCount} 张</small>
            </span>
          </a>
        ))}
      </nav>

      <div class="category-list">
        {categories.map((category) => (
          <section id={category.id} class="category-section" aria-labelledby={`${category.id}-title`}>
            <div class="category-header">
              {category.coverURL && (
                <img
                  class="category-cover"
                  src={category.coverPreviewURL}
                  data-fallback-src={category.coverURL}
                  onerror={imageFallbackHandler}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              )}

              <div class="category-meta">
                <div class="section-kicker">{category.imageCount} 张图片</div>
                <h2 id={`${category.id}-title`}>{category.name}</h2>
                {category.description && <p>{category.description}</p>}
              </div>
            </div>

            <div class="gallery-grid" data-pswp-gallery>
              {category.images.map((image) => (
                <figure class="gallery-card">
                  <a
                    class="gallery-media"
                    href={image.url}
                    data-gallery-link
                    data-gallery-name={image.name}
                    data-gallery-description={image.description ?? ''}
                    data-gallery-origin={image.origin ?? ''}
                    data-pswp-width={image.width}
                    data-pswp-height={image.height}
                    data-pswp-size-source={image.hasOriginalSize ? 'data' : undefined}
                    aria-label={`放大查看 ${image.name}`}
                  >
                    <img
                      src={image.previewURL}
                      data-fallback-src={image.url}
                      onerror={imageFallbackHandler}
                      alt={image.alt}
                      loading={image.index < 6 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </a>

                  <figcaption>
                    <div class="image-title">{image.name}</div>
                    {image.description && <p>{image.description}</p>}
                    {image.origin && (
                      <a class="origin-link" href={image.origin} target="_blank" rel="noreferrer">
                        Origin
                      </a>
                    )}
                  </figcaption>
                </figure>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </HeaderFooterLayout>
</Layout>

<script>
  import '@/scripts/gallery'
</script>

<style>
  .gallery-page {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 5rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero {
    min-height: clamp(300px, 44svh, 480px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .hero-copy {
    max-width: 650px;
  }

  .eyebrow,
  .section-kicker {
    color: rgba(255, 255, 255, 0.62);
    font-family: var(--font-cascadia-code);
    font-size: 0.84rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1 {
    margin-top: 0.35rem;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.95;
    color: #fff;
    text-shadow: 0 8px 32px rgba(0, 0, 0, 0.32);
  }

  .hero-copy p {
    max-width: 36rem;
    margin-top: 1.25rem;
    color: rgba(255, 255, 255, 0.76);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .hero-covers {
    position: relative;
    height: min(410px, 46vw);
    min-height: 280px;
  }

  .hero-cover {
    position: absolute;
    width: 72%;
    height: 82%;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
  }

  .hero-cover-1 {
    right: 0;
    top: 4%;
    z-index: 3;
  }

  .hero-cover-2 {
    left: 0;
    bottom: 0;
    z-index: 2;
    transform: rotate(-4deg);
    opacity: 0.78;
  }

  .hero-cover-3 {
    right: 14%;
    bottom: 6%;
    z-index: 1;
    transform: rotate(5deg);
    opacity: 0.52;
  }

  .category-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.85rem;
    margin: 0 0 3rem;
  }

  .category-link {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem;
    color: inherit;
    text-decoration: none;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    box-shadow: var(--glass-shadow);
    backdrop-filter: var(--glass-blur-sm);
    -webkit-backdrop-filter: var(--glass-blur-sm);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .category-link:hover {
    transform: translateY(-2px);
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-strong);
  }

  .category-link img {
    width: 56px;
    height: 56px;
    flex: 0 0 auto;
    object-fit: cover;
    border-radius: 6px;
  }

  .category-link span {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .category-link strong {
    overflow: hidden;
    color: #fff;
    font-size: 1rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .category-link small {
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.82rem;
  }

  .category-list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .category-section {
    scroll-margin-top: 88px;
  }

  .category-header {
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr);
    gap: 1.25rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .category-cover {
    width: 132px;
    height: 132px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: var(--glass-shadow);
  }

  .category-meta {
    min-width: 0;
  }

  .category-meta h2 {
    margin-top: 0.25rem;
    color: #fff;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
  }

  .category-meta p {
    max-width: 48rem;
    margin-top: 0.7rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
  }

  .gallery-grid {
    columns: 4 230px;
    column-gap: 1rem;
  }

  .gallery-card {
    break-inside: avoid;
    margin: 0 0 1rem;
    overflow: hidden;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    box-shadow: var(--glass-shadow);
    backdrop-filter: var(--glass-blur-sm);
    -webkit-backdrop-filter: var(--glass-blur-sm);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .gallery-card:hover {
    transform: translateY(-3px);
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-strong);
  }

  .gallery-media {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .gallery-media img {
    display: block;
    width: 100%;
    min-height: 160px;
    max-height: 520px;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.06);
  }

  figcaption {
    padding: 0.75rem 0.85rem 0.85rem;
  }

  .image-title {
    overflow-wrap: anywhere;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-cascadia-code);
    font-size: 0.84rem;
    line-height: 1.45;
  }

  figcaption p {
    margin-top: 0.35rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .origin-link {
    display: inline-flex;
    margin-top: 0.55rem;
    color: rgba(255, 255, 255, 0.72);
    font-family: var(--font-cascadia-code);
    font-size: 0.78rem;
    text-decoration: none;
  }

  .origin-link:hover {
    color: #fff;
  }

  :global(.pswp__caption) {
    position: absolute;
    right: 50%;
    bottom: 18px;
    z-index: 1;
    width: min(680px, calc(100vw - 32px));
    padding: 0.8rem 1rem;
    color: rgba(255, 255, 255, 0.88);
    text-align: center;
    background: rgba(0, 0, 0, 0.48);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    transform: translateX(50%);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  :global(.pswp-caption-title) {
    overflow-wrap: anywhere;
    font-family: var(--font-cascadia-code);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  :global(.pswp-caption-description) {
    margin-top: 0.35rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  :global(.pswp-caption-origin) {
    display: inline-flex;
    margin-top: 0.4rem;
    color: rgba(255, 255, 255, 0.82);
    font-family: var(--font-cascadia-code);
    font-size: 0.78rem;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .gallery-page {
      width: min(100% - 1.5rem, 1180px);
      padding: 2rem 0 3rem;
    }

    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero-covers {
      height: 260px;
      min-height: 260px;
      order: -1;
    }

    .hero-copy p {
      font-size: 1rem;
    }

    .category-nav {
      grid-template-columns: 1fr;
      margin-top: 2rem;
    }

    .category-header {
      grid-template-columns: 86px minmax(0, 1fr);
    }

    .category-cover {
      width: 86px;
      height: 86px;
    }

    .gallery-grid {
      columns: 2 150px;
      column-gap: 0.75rem;
    }

    .gallery-card {
      margin-bottom: 0.75rem;
    }

    .gallery-media img {
      min-height: 120px;
      max-height: 360px;
    }

    figcaption {
      padding: 0.65rem 0.7rem 0.75rem;
    }
  }

  @media (max-width: 520px) {
    .hero-covers {
      height: 220px;
      min-height: 220px;
    }

    .gallery-grid {
      columns: 1;
    }

    :global(.pswp__caption) {
      bottom: 12px;
      width: calc(100vw - 24px);
      padding: 0.7rem 0.8rem;
    }
  }
</style>
