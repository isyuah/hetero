---
import Layout from "@/layouts/Layout.astro";
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export const getStaticPaths = (async () => {
  const availablePosts = getPostCollectionWithDate(await getCollection('posts', ({data}) => !data.draft))
  return availablePosts.map(post => {
    return {
      params: {
        filename: post.id,
      },
      props: {
        post
      }
    }
  })
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const {data} = post;
const {Content, headings} = await render(post);

import "@/styles/markdown.css"
import HeaderFooterL from "@/layouts/HeaderFooterL.astro";
import { getPostCollectionWithDate } from "@/utils/post";
---

<Layout>
  <HeaderFooterL gradientBackground>
    <div class="main">
      <article>
        <h1 class="title">{data.title}</h1>
        <div class="meta">
          <div class="date-meta">{post.time.updatedAt.getTime() === post.time.createdAt.getTime() ? `发布于 ` : `最后更新于 ` + post.time.updatedAt.toLocaleDateString('zh-CN')}</div>
          {data.tags.length && <div class="tags">
            {data.tags.map(tag => <a href={`/tags/${tag}`} class="tag">{tag}</a>)}
          </div>}
        </div>

        <div class="MARKDOWN">
          <Content></Content>
        </div>
      </article>
      <nav class="TOC">
        <div class="toc-title">TABLE OF CONTENT</div>
        {headings.filter(h => h.depth < 4).map(heading => {
          return <a href={`#${heading.slug}`} class={`depth-${heading.depth}`}>{heading.text}</a>
        })}
      </nav>
    </div>
  </HeaderFooterL>
</Layout>

<script>
  const headingsEl = document.querySelectorAll('article h1, article h2, article h3');
  const ob = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const link = document.querySelector(`.TOC a[href="#${entry.target.id}"]`)
      if (!link) return;
      if (entry.isIntersecting) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    })
  }, {
    rootMargin: '0px 0px -40% 0px',
    threshold: 0,
  })
  headingsEl.forEach(e => ob.observe(e))
</script>

<style>
  .main {
    position: relative;
    display: grid;
    column-gap: 1rem;
    grid-template-columns: 1fr 300px;
    width: 100%;
  }
  .TOC {
    align-self: flex-start;
    overflow-y: auto;
    position: sticky;
    display: flex;
    flex-direction: column;
    top: 4rem;
    max-height: calc(100vh - 64px - 4rem);
    margin: 2rem 0;
    margin-right: 2rem;
    min-width: 0;
    border-left: none;
    padding-left: 0;

    .toc-title {
      user-select: none;
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #94a3b8;
      padding: 0.25rem 0.75rem;
      margin-bottom: 0.25rem;
    }

    a {
      position: relative;
      color: #64748b;
      font-size: 0.85rem;
      line-height: 1.4;
      padding: 0.3rem 0.75rem;
      border-left: 2px solid #e2e8f0;
      text-decoration: none;
      transition: all 0.2s ease;
    }
    a:hover {
      color: #334155;
      background: #f1f5f9;
    }
    a.active {
      color: #3b82f6;
      border-left-color: #3b82f6;
      background: #eff6ff;
      font-weight: 500;
    }
    a.depth-2 { padding-left: 0.75rem; }
    a.depth-3 { padding-left: 1.5rem; font-size: 0.8rem; }
  }
  .TOC {
    scrollbar-width: thin;
    scrollbar-color: rgba(150,150,150,0.3) transparent;
  }
  .TOC::-webkit-scrollbar {
    width: 4px;
  }
  .TOC::-webkit-scrollbar-track {
    background: transparent;
  }
  .TOC::-webkit-scrollbar-thumb {
    background: rgba(150,150,150,0.4);
    border-radius: 2px;
  }
  .TOC::-webkit-scrollbar-thumb:hover {
    background: rgba(150,150,150,0.7);
  }

  article {
    min-width: 0;
    margin: 2rem 4rem;
    padding: 1rem;

    .title {
      color: #22272e;
      font-size: 2.25rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }
    .meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      margin-bottom: 2rem;
      color: oklch(44.6% 0.043 257.281);

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        .tag::before {
          content: '# ';
        }
        .tag:hover {
          display: block;
          text-decoration: none;
          cursor: pointer;
          color: #5082c8;
        }
      }
    }
  }
</style>