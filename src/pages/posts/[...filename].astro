---
import Layout from "@/layouts/Layout.astro";
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export const getStaticPaths = (async () => {
  const availablePosts = getPostCollectionWithDate(await getCollection('posts', ({data}) => !data.draft))
  return availablePosts.map(post => {
    return {
      params: {
        filename: post.id,
      },
      props: {
        post
      }
    }
  })
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const {data} = post;
const {Content, headings} = await render(post);
import "@/styles/markdown.css"
import HeaderFooterLayout from "@/layouts/HeaderFooterLayout.astro";
import { getPostCollectionWithDate } from "@/utils/post";
import { Icon } from "astro-icon/components";
---

<Layout>
  <HeaderFooterLayout gradientBackground>
    <div class="main">
      <article>
        <h1 class="title">{data.title}</h1>
        <div class="meta">
          <div class="date-meta">{(post.time.updatedAt === post.time.createdAt ? `发布于 ` : `最后更新于 `) + new Date(post.time.updatedAt).toLocaleDateString('zh-CN')}</div>
          {data.tags.length > 0 && <div class="tags">
            {data.tags.map(tag => <a href={`/posts/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>)}
          </div>}
        </div>

        <div class="MARKDOWN">
          <Content></Content>
        </div>
      </article>
    </div>
  </HeaderFooterLayout>
  <div class="toc-mask"></div>
  <nav class="TOC" id="toc">
    <div class="toc-title">TABLE OF CONTENT</div>
    {headings.filter(h => h.depth < 4).map(heading => {
      return <a href={`#${heading.slug}`} class={`depth-${heading.depth}`}>{heading.text}</a>
    })}
  </nav>
  <div class="TOC-button">
    <Icon name="mdi:menu" width={32} height={32}></Icon>
  </div>
</Layout>

<script is:inline data-astro-rerun>
  (() => {
    window.__postTocCleanup?.();

    const toc = document.querySelector('#toc');
    const tocMask = document.querySelector('.toc-mask');
    const tocButton = document.querySelector('.TOC-button');
    const headings = document.querySelectorAll('article h1[id], article h2[id], article h3[id]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const link = document.querySelector(`.TOC a[href="#${entry.target.id}"]`);
        if (!link) return;

        link.classList.toggle('active', entry.isIntersecting);
      });
    }, {
      rootMargin: '0px 0px -40% 0px',
      threshold: 0,
    });

    headings.forEach((heading) => observer.observe(heading));

    const closeToc = () => {
      toc?.classList.remove('open');
      tocMask?.classList.remove('open');
    };

    const toggleToc = () => {
      toc?.classList.toggle('open');
      tocMask?.classList.toggle('open');
    };

    tocMask?.addEventListener('click', closeToc);
    tocButton?.addEventListener('click', toggleToc);
    toc?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeToc);
    });

    window.__postTocCleanup = () => {
      observer.disconnect();
      tocMask?.removeEventListener('click', closeToc);
      tocButton?.removeEventListener('click', toggleToc);
      toc?.querySelectorAll('a').forEach((link) => {
        link.removeEventListener('click', closeToc);
      });
      delete window.__postTocCleanup;
    };
  })();
</script>

<style>
  .main {
    position: relative;
    display: grid;
    column-gap: 1.5rem;
    grid-template-columns: 1fr 280px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    box-sizing: border-box;
  }
  .TOC {
    position: fixed;
    right: max(1rem, calc((100vw - 1200px) / 2 + 2rem));
    top: calc(64px + 1.5rem);
    width: 260px;
    max-height: calc(100vh - 64px - 3rem);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    margin: 1.5rem 0;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius);
    box-shadow: var(--glass-shadow);
    padding: 1rem 0;
    z-index: 10;

    .toc-title {
      user-select: none;
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: rgba(255, 255, 255, 0.5);
      padding: 0.25rem 1rem;
      margin-bottom: 0.25rem;
    }

    a {
      position: relative;
      color: rgba(255, 255, 255, 0.65);
      font-size: 0.85rem;
      line-height: 1.4;
      padding: 0.35rem 1rem;
      border-left: 2px solid rgba(255, 255, 255, 0.1);
      text-decoration: none;
      transition: all 0.2s ease;
      margin: 0 0.5rem;
    }
    a:hover {
      color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.08);
      border-left-color: rgba(255, 255, 255, 0.3);
    }
    a.active {
      color: rgba(255, 255, 255, 0.95);
      border-left-color: rgba(255, 255, 255, 0.7);
      background: rgba(255, 255, 255, 0.1);
      font-weight: 500;
    }
    a.depth-2 { padding-left: 1rem; }
    a.depth-3 { padding-left: 1.75rem; font-size: 0.8rem; }
  }
  .TOC {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.4) transparent;
  }
  .TOC::-webkit-scrollbar {
    width: 4px;
    background: transparent;
  }
  .TOC::-webkit-scrollbar-track {
    background: transparent;
    border: none;
  }
  .TOC::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.4);
    border-radius: 2px;
  }
  .TOC::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  article {
    min-width: 0;
    margin: 1.5rem 0;
    padding: 2.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius-lg);
    box-shadow: var(--glass-shadow-lg);

    .title {
      color: rgba(255, 255, 255, 0.95);
      font-size: 2.25rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }
    .meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      margin-bottom: 2rem;
      color: rgba(255, 255, 255, 0.55);

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        .tag {
          color: rgba(255, 255, 255, 0.55);
          text-decoration: none;
          font-size: 0.85rem;
          transition: color 0.2s;
        }
        .tag::before {
          content: '# ';
        }
        .tag:hover {
          color: rgba(255, 255, 255, 0.9);
        }
      }
    }
  }

  .TOC-button {
    position:fixed;
    display: none;
  }

  @media (max-width: 768px) {
    .toc-mask {
      opacity: 0;
      position: fixed;
      background-color: rgba(0, 0, 0, .5);
      backdrop-filter: blur(4px);
      left: 0;
      right: 0;
      top: 0;
      bottom: 0;
      z-index: 101;
      pointer-events: none;
      transition: opacity .25s;
    }
    .toc-mask.open {
      opacity: 1;
      pointer-events: all;
    }
    .main {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }
    .TOC {
      position: fixed;
      right: 0;
      top: 0;
      height: 100svh;
      width: auto;
      margin: 0;
      max-width: calc(100vw - 2rem);
      transform: translateX(120%);
      z-index: 102;
      transition: transform .25s, visibility .25s;
      box-shadow: 0 0 48px rgba(0, 0, 0, .3);
      padding: 1rem 0;
      visibility: hidden;
      max-height: none;
      border-radius: 0;
    }
    .TOC.open {
      width: fit-content;
      transform: translateX(0);
      visibility: visible;
    }
    .TOC-button {
      display: flex;
      bottom: 1.5rem;
      right: 1.5rem;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--glass-bg-strong);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid var(--glass-border-strong);
      color: #ffffff;
      box-shadow: var(--glass-shadow-lg);
      align-items: center;
      justify-content: center;
      z-index: 100;
      cursor: pointer;
    }
    article {
      margin: 1rem 0;
      padding: 1.25rem;
      border-radius: var(--glass-radius);
    }
  }
</style>
