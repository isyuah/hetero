---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getPostCollectionWithDate } from "@/utils/post";
import HeaderFooterLayout from "@/layouts/HeaderFooterLayout.astro";
import PostCard from "@/components/PostCard.astro";

const posts = getPostCollectionWithDate(
  await getCollection('posts', ({data}) => !data.draft && data.showInPosts)
).toSorted((a, b) => b.time.updatedAt - a.time.updatedAt);

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Layout>
  <HeaderFooterLayout gradientBackground>
    <div class="posts-page">
      <div class="page-header">
        <h1>文章</h1>
        <p class="subtitle">共 {posts.length} 篇</p>
      </div>

      <div class="filters">
        <input type="text" class="search-input" placeholder="搜索文章..." />
        <div class="tag-chips">
          <button class="chip active" data-tag="">全部</button>
          {allTags.map(tag => <button class="chip" data-tag={tag}>{tag}</button>)}
        </div>
      </div>

      <div class="post-list">
        {posts.map(post => <PostCard post={post} />)}
      </div>

      <div class="no-results" style="display:none">没有找到匹配的文章</div>
    </div>
  </HeaderFooterLayout>
</Layout>

<script>
  const cards = document.querySelectorAll<HTMLAnchorElement>('.post-card');
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const searchInput = document.querySelector<HTMLInputElement>('.search-input')!;
  const noResults = document.querySelector<HTMLDivElement>('.no-results')!;

  let activeTag = '';

  function filterPosts() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    cards.forEach(card => {
      const tags = card.dataset.tags ?? '';
      const title = card.dataset.title ?? '';
      const desc = card.dataset.desc ?? '';

      const matchesTag = !activeTag || tags.split(',').includes(activeTag);
      const matchesSearch = !query || title.includes(query) || desc.includes(query);

      const visible = matchesTag && matchesSearch;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    noResults.style.display = visibleCount === 0 ? '' : 'none';
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeTag = chip.dataset.tag ?? '';
      filterPosts();
    });
  });

  searchInput.addEventListener('input', filterPosts);
</script>

<style>
  .posts-page {
    max-width: 1000px;
    width: min(92%, 1000px);
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    box-sizing: border-box;
  }

  .page-header {
    margin-bottom: 1.5rem;
    h1 {
      font-size: 1.8rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.9);
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }
    .subtitle {
      margin-top: 0.25rem;
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.55);
    }
  }

  .filters {
    margin-bottom: 1.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius);
    padding: 1.25rem;
    box-shadow: var(--glass-shadow);
  }

  .search-input {
    width: 100%;
    padding: 0.7rem 1rem;
    font-size: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    outline: none;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.9);
    transition: all 0.25s;
    &::placeholder {
      color: rgba(255, 255, 255, 0.4);
    }
    &:focus {
      border-color: rgba(255, 255, 255, 0.45);
      background: rgba(255, 255, 255, 0.18);
      box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.06);
    }
  }

  .tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .chip {
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: all 0.2s;
    &:hover {
      border-color: rgba(255, 255, 255, 0.45);
      color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.15);
    }
    &.active {
      background: rgba(255, 255, 255, 0.25);
      border-color: rgba(255, 255, 255, 0.5);
      color: #fff;
      font-weight: 600;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    }
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .no-results {
    text-align: center;
    padding: 3rem 0;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .posts-page {
      padding: 1.5rem 1rem 3rem;
    }
  }
</style>
