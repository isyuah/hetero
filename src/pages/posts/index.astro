---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getPostCollectionWithDate } from "@/utils/post";
import HeaderFooterLayout from "@/layouts/HeaderFooterLayout.astro";
import PostCard from "@/components/PostCard.astro";
import PostTagsNav from "@/components/PostTagsNav.astro";

const posts = getPostCollectionWithDate(
  await getCollection('posts', ({data}) => !data.draft && data.showInPosts)
).toSorted((a, b) => b.time.updatedAt - a.time.updatedAt);

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Layout>
  <HeaderFooterLayout gradientBackground>
    <div class="posts-page">
      <div class="page-header" transition:name="posts-page-header" transition:animate="fade">
        <h1>文章</h1>
        <p class="subtitle">共 {posts.length} 篇</p>
      </div>

      <div class="filters" transition:name="posts-filter" transition:animate="fade">
        <input type="text" class="search-input" placeholder="搜索文章..." />
      </div>

      <PostTagsNav allTags={allTags} />

      <div class="post-list" transition:name="posts-list" transition:animate="fade">
        {posts.map(post => <PostCard post={post} />)}
      </div>

      <div class="no-results" style="display:none">没有找到匹配的文章</div>
    </div>
  </HeaderFooterLayout>
</Layout>

<script>
  import Fuse from "fuse.js";

  const cards = document.querySelectorAll<HTMLAnchorElement>('.post-card');
  const searchInput = document.querySelector<HTMLInputElement>('.search-input')!;
  const noResults = document.querySelector<HTMLDivElement>('.no-results')!;

  let fuse: Fuse<any> | null = null;

  const indexPromise = fetch("/search-index.json")
    .then(res => res.json())
    .then(posts => {
      fuse = new Fuse(posts, {
        includeScore: true,
        ignoreLocation: true,
        threshold: 0.35,
        minMatchCharLength: 2,
        keys: [
          { name: "title", weight: 5 },
          { name: "desc", weight: 3 },
          { name: "tags", weight: 3 },

          { name: "initials", weight: 4 },
          { name: "pinyinCompact", weight: 4 },
          { name: "pinyin", weight: 3 },

          { name: "text", weight: 1.5 },
        ],
      });
    });

  function filterPosts() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    // Resolve which post IDs match the search query
    let matchedIds: Set<string> | null = null;
    if (query && fuse) {
      matchedIds = new Set(fuse.search(query).map(r => r.item.id));
    }

    cards.forEach(card => {
      const matchesSearch = !matchedIds || matchedIds.has(card.dataset.postId ?? '');

      const visible = matchesSearch;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    noResults.style.display = visibleCount === 0 ? '' : 'none';
  }

  searchInput.addEventListener('input', async () => {
    await indexPromise;
    filterPosts();
  });
</script>

<style>
  .posts-page {
    max-width: 1000px;
    width: min(92%, 1000px);
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    box-sizing: border-box;
  }

  .page-header {
    margin-bottom: 1.5rem;
    h1 {
      font-size: 1.8rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.9);
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }
    .subtitle {
      margin-top: 0.25rem;
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.55);
    }
  }

  .filters {
    margin-bottom: 1.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius);
    padding: 1.25rem;
    box-shadow: var(--glass-shadow);
  }

  .search-input {
    width: 100%;
    padding: 0.7rem 1rem;
    font-size: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    outline: none;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.9);
    transition: all 0.25s;
    &::placeholder {
      color: rgba(255, 255, 255, 0.4);
    }
    &:focus {
      border-color: rgba(255, 255, 255, 0.45);
      background: rgba(255, 255, 255, 0.18);
      box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.06);
    }
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .no-results {
    text-align: center;
    padding: 3rem 0;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .posts-page {
      padding: 1.5rem 1rem 3rem;
    }
  }
</style>
