---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import siteConfig from '@/config/site.config.ts'
const {avatar, github} = siteConfig;
import '@/styles/animations.css'
import { getCollection } from "astro:content";
import { getPostCollectionWithDate } from "@/utils/post";
import HeaderFooterLayout from "@/layouts/HeaderFooterLayout.astro";
import PostCard from "@/components/PostCard.astro";
const posts = getPostCollectionWithDate(await getCollection('posts', ({data}) => !data.draft && data.showInPosts)).toSorted((pa, pb) => pb.time.updatedAt - pa.time.updatedAt);
---

<Layout>
  <HeaderFooterLayout gradientBackground>
    <div class="banner">
        <img class="avatar" src={avatar} alt="Avatar">
        <div class="username">@isyuah</div>
        <a href={github} target="_blank" class="media">
          <Icon width={24} height={24} name="mdi:github" />
          <span>GitHub</span>
        </a>
        <section>
          <div id="About" class="section-title">About</div>
          <div class="content">{siteConfig.shortAbout}</div>
        </section>
        <section class="skills">
          <div id="Skills" class="section-title">Skills</div>
          <div class="content">
            {siteConfig.skills.map(st => {
              return <div class="type">
                <div class="type-title">{st.title}</div>
                <div class="type-content">
                  {st.tags.map(tag => {
                    if (tag.url) {
                      return <a href={tag.url} referrerpolicy="no-referrer" target="_blank" class="tag">{tag.name}</a>
                    } else {
                      return <span class="tag">{tag.name}</span>
                    }
                  })}
                </div>
              </div>
            })}
          </div>
        </section>
        <section class="posts">
          <div class="section-title">Posts</div>
          <div class="content">
            {posts.map(post => <PostCard post={post} />)}
          </div>
        </section>
      </div>
  </HeaderFooterLayout>
</Layout>

<style>
  .banner {
    padding: 2rem 0 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    img.avatar {
      width: 108px;
      height: 108px;
      padding: 4px;
      border: 2px solid rgba(255, 255, 255, 0.25);
      background: transparent;
      border-radius: 50%;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
      object-fit: cover;
    }
    .username {
      margin-top: -0.25rem;
      font-size: 1.4rem;
      font-family: var(--font-cascadia-code);
      color: #fff;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.4);
      letter-spacing: 1px;
      font-weight: 500;
    }
    .media {
      margin-top: -0.5rem;
      font-family: var(--font-cascadia-code);
      display: flex;
      gap: 8px;
      align-items: center;
      cursor: pointer;
      color: rgba(255, 255, 255, 0.75);
      text-decoration: none;
      padding: 6px 16px;
      border-radius: 999px;
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur-sm);
      -webkit-backdrop-filter: var(--glass-blur-sm);
      border: 1px solid var(--glass-border);
      transition: all .25s;
      font-size: 0.9rem;
      &:hover {
        color: rgba(255, 255, 255, 1);
        background: var(--glass-bg-hover);
        border-color: var(--glass-border-strong);
        transform: translateY(-1px);
      }
    }


    & > section {
      margin: 0 5%;
      padding: 0;
      display: flex;
      gap: clamp(40px, 4vw, 80px);
      animation: fade-in-from-bottom .5s ease both;
      width: min(90%, 900px);
      .section-title {
        min-width: fit-content;
        font-weight: 700;
        font-size: 1.4rem;
        align-self: flex-start;
        color: rgba(255, 255, 255, 0.85);
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      }
      .section-title::before {
        content: '# ';
      }
      .content {
        margin-top: 20px;
        padding: 1.25rem 1.5rem;
        white-space: pre-wrap;
        width: clamp(0px, 50vw, 850px);
        min-width: 0;
        color: rgba(255, 255, 255, 0.85);
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--glass-radius);
        box-shadow: var(--glass-shadow);
        line-height: 1.75;
      }
    }
  }

  .banner section.skills .content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .banner section.skills .content .type {
    display: flex;
    flex-direction: column;
    gap: 10px;
    .type-content {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      .tag {
        padding: 4px 12px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: rgba(255, 255, 255, 0.85);
        background: rgba(255, 255, 255, 0.1);
        font-size: 0.85rem;
        letter-spacing: 0.2px;
        white-space: nowrap;
        text-decoration: none;
        transition: all .25s;
      }
      a.tag {
        cursor: pointer;
      }
    }
    &:nth-child(2) .tag {
      border-color: rgba(129, 230, 180, 0.5);
      color: rgba(190, 255, 220, 0.95);
    }
    &:nth-child(3) .tag {
      border-color: rgba(180, 160, 230, 0.5);
      color: rgba(210, 195, 255, 0.95);
    }
  }
  .banner section.skills .content .type .type-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.2px;
  }
  .banner section.skills .content .type .type-content .tag:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .banner section.posts .content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0;
    background: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border: none;
    border-radius: 0;
    box-shadow: none;
  }
  @media (max-width: 768px) {
    .banner {
      padding: 1rem 0 2rem;
    }
    .banner section {
      width: 100%;
      margin-left: 0;
      margin-right: 0;
      padding: 0 0.75rem;
      flex-direction: column;
      gap: 10px;
      .content {
        margin-top: 0px;
      }
      .content{
        width: 100%;
        padding: 1rem;
      }
    }
  }
</style>
