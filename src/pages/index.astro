---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import siteConfig from '@/config/site.config.ts'
const {avatar, github} = siteConfig;
import '@/styles/animations.css'
import { getCollection } from "astro:content";
import { getPostCollectionWithDate } from "@/utils/post";
import HeaderFooterLayout from "@/layouts/HeaderFooterLayout.astro";
const posts = getPostCollectionWithDate(await getCollection('posts', ({data}) => !data.draft && data.showInPosts)).toSorted((pa, pb) => pb.time.updatedAt - pa.time.updatedAt);
---

<Layout>
  <HeaderFooterLayout gradientBackground>
    <main>
      <div class="banner">
        <img class="avatar" src={avatar} alt="Avatar">
        <div class="username">@isyuah</div>
        <a href={github} target="_blank" class="media">
          <Icon width={24} height={24} name="mdi:github" />
          <span>GitHub</span>
        </a>
        <section>
          <div id="About" class="section-title">About</div>
          <div class="content">{siteConfig.shortAbout}</div>
        </section>
        <section class="skills">
          <div id="Skills" class="section-title">Skills</div>
          <div class="content">
            {siteConfig.skills.map(st => {
              return <div class="type">
                <div class="type-title">{st.title}</div>
                <div class="type-content">
                  {st.tags.map(tag => {
                    if (tag.url) {
                      return <a href={tag.url} referrerpolicy="no-referrer" target="_blank" class="tag">{tag.name}</a>
                    } else {
                      return <span class="tag">{tag.name}</span>
                    }
                  })}
                </div>
              </div>
            })}
          </div>
        </section>
        <section class="posts">
          <div class="section-title">Posts</div>
          <div class="content">
            {posts.map(post => <a href={`/posts/${post.id}`} class="post">
              <div class="post-title">{post.data.title}</div>
              <div class="post-desc">{post.data.desc}</div>
              <div class="post-meta">
                <span class="post-date"><Icon width={14} height={14} name="mdi:calendar-plus" />{new Date(post.time.createdAt).toLocaleDateString("zh-CN")}</span>
                <span class="post-date"><Icon width={14} height={14} name="mdi:calendar-edit" />{new Date(post.time.updatedAt).toLocaleDateString("zh-CN")}</span>
              </div>
            </a>)}
          </div>
        </section>
      </div>
    </main>
  </HeaderFooterLayout>
</Layout>

<style>
  .banner {
    padding-top: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    img.avatar {
      width: 108px;
      height: 108px;
      padding: 6px;
      border: 1px solid #ccc;
      background-color: #fff;
      border-radius: 50%;
    }
    .username {
      margin-top: 5px;
      font-size: 1.5rem;
      font-family: var(--font-cascadia-code);
    }
    .media {
      margin-top: 3px;
      font-family: var(--font-cascadia-code);
      display: flex;
      gap: 6px;
      align-items: center;
      cursor: pointer;
      color: #555;
      transition: color .2s;
      &:hover {
        color: #000;
      }
    }


    & > section {
      /* align-self: stretch; */
      margin: 20px 5% 0;
      padding: 0 5%;
      display: flex;
      gap: clamp(40px, 4vw, 80px);
      animation: fade-in-from-bottom .5s;
      .section-title {
        min-width: fit-content;
        font-weight: 700;
        font-size: 1.4rem;
        align-self: flex-start;
        color: #152b32;
      }
      .section-title::before {
        content: '# ';
      }
      .content {
        margin-top: 20px;
        white-space: pre-wrap;
        width: clamp(0px, 50vw, 850px);
        min-width: 0;
        color: #334155;
      }
    }
  }

  .banner section.skills .content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .banner section.skills .content .type {
    display: flex;
    flex-direction: column;
    gap: 10px;
    .type-content {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      .tag {
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #5082c8;
        color: #5082c8;
        font-size: 0.85rem;
        letter-spacing: 0.2px;
        white-space: nowrap;
        transition: all .2s;
      }
      a.tag {
        cursor: pointer;
      }
    }
    &:nth-child(2) .tag {
      color: #41a97a;
      border-color: #41a97a;
    }
    &:nth-child(3) .tag {
      color: #7142b3;
      border-color: #7142b3;
    }
  }
  .banner section.skills .content .type .type-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 0.2px;
  }
  .banner section.skills .content .type .type-content .tag:hover {
    transform: translateY(-2px);
  }

  .banner section.posts .content {
    display: flex;
    flex-direction: column;
    .post {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 16px 14px;
      width: 100%;
      border-bottom: 1px solid #e2e8f0;
      transition: background-color .2s;
      &:first-child {
        border-top: 1px solid #e2e8f0;
      }
      &:hover {
        background-color: #f1f5f9;
      }
      .post-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
      }
      .post-desc {
        font-size: 0.88rem;
        color: #64748b;
        line-height: 1.5;
      }
      .post-meta {
        display: flex;
        gap: 12px;
      }
      .post-date {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 0.78rem;
        font-family: var(--font-cascadia-code);
        color: #94a3b8;
      }
    }
  }
  @media (max-width: 768px) {
    .banner section {
      width: 100%;
      margin-left: 0;
      margin-right: 0;
      padding: 0 1rem;
      flex-direction: column;
      gap: 18px;
      .content {
        margin-top: 0px;
      }
      .content{
        width: 100%;
      }
    }
  }
</style>
