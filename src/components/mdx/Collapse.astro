---
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  open?: boolean;
}

const {
  title = "Details",
  open = false,
} = Astro.props;
---

<details class="collapse-block" open={open}>
  <summary class="collapse-block__summary">
    <span class="collapse-block__chevron" aria-hidden="true">
      <Icon name="mdi:chevron-right" width={20} height={20} />
    </span>
    <span class="collapse-block__title">{title}</span>
  </summary>
  <div class="collapse-block__body">
    <slot />
  </div>
</details>

<style>
  .collapse-block {
    margin: 1.2rem 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--glass-radius-sm);
    background: rgba(255, 255, 255, 0.055);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
  }

  .collapse-block[open] {
    background:
      linear-gradient(180deg, rgba(180, 210, 255, 0.07), transparent 46%),
      rgba(255, 255, 255, 0.055);
  }

  .collapse-block__summary {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.78rem 0.95rem;
    color: rgba(255, 255, 255, 0.9);
    cursor: pointer;
    font-weight: 700;
    line-height: 1.4;
    list-style: none;
  }

  .collapse-block__summary::-webkit-details-marker {
    display: none;
  }

  .collapse-block__summary:hover {
    background: rgba(180, 210, 255, 0.08);
  }

  .collapse-block__chevron {
    display: inline-flex;
    flex: 0 0 auto;
    color: rgba(180, 210, 255, 0.9);
    transition: transform 0.2s ease;
  }

  .collapse-block[open] .collapse-block__chevron {
    transform: rotate(90deg);
  }

  .collapse-block__title {
    min-width: 0;
  }

  .collapse-block__body {
    padding: 0 0.95rem 0.95rem;
    color: rgba(255, 255, 255, 0.82);
  }

  .collapse-block__body > :first-child {
    margin-top: 0;
  }

  .collapse-block__body > :last-child {
    margin-bottom: 0;
  }
</style>
