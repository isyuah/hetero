---
import { Icon } from "astro-icon/components";
import { getUrlHostLabel } from "@/utils/linkPreview";

interface Props {
  url: string;
  title?: string;
  desc?: string;
  icon?: string | false | null;
  auto?: boolean;
}

const { url, title, desc, icon, auto = true } = Astro.props;
const host = getUrlHostLabel(url);
const cardTitle = (title ?? host).trim() || host;
const cardIcon = icon === false || icon === null ? undefined : icon;
const hasIcon = typeof cardIcon === "string" && cardIcon.trim().length > 0;
const isIconUrl = hasIcon && /^(https?:|data:|\/)/i.test(cardIcon);
---

<a
  class:list={["mdx-card", "mdx-link-card", !hasIcon && "mdx-card--no-icon"]}
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  referrerpolicy="no-referrer"
  data-link-card-live
  data-url={url}
  data-auto={String(auto)}
  data-title-locked={String(title !== undefined)}
  data-desc-locked={String(desc !== undefined)}
  data-icon-locked={String(icon !== undefined)}
>
  <span class="mdx-card__icon" data-card-icon-wrap hidden={!hasIcon}>
    {hasIcon && (
      isIconUrl
        ? <img src={cardIcon} alt="" loading="lazy" decoding="async" data-card-icon-img />
        : <Icon name={cardIcon} width={26} height={26} />
    )}
  </span>
  <span class="mdx-card__body">
    <span class="mdx-card__title" data-card-title>{cardTitle}</span>
    <span class="mdx-card__desc" data-card-desc hidden={!desc}>{desc}</span>
    <span class="mdx-card__meta">
      <span class="mdx-card__host" data-card-host>{host}</span>
    </span>
  </span>
  <span class="mdx-card__arrow" aria-hidden="true">
    <Icon name="mdi:open-in-new" width={18} height={18} />
  </span>
</a>

<script>
  type LinkPreviewResponse = {
    ok: boolean;
    data?: {
      finalUrl?: string;
      title?: string;
      desc?: string;
      icon?: string;
    };
  };

  const setLiveLinkIcon = (card: HTMLElement, iconUrl: string) => {
    const wrap = card.querySelector<HTMLElement>("[data-card-icon-wrap]");
    if (!wrap) return;

    wrap.replaceChildren();
    const img = document.createElement("img");
    img.src = iconUrl;
    img.alt = "";
    img.loading = "lazy";
    img.decoding = "async";
    img.addEventListener("error", () => {
      wrap.hidden = true;
      card.classList.add("mdx-card--no-icon");
    });
    wrap.append(img);
    wrap.hidden = false;
    card.classList.remove("mdx-card--no-icon");
  };

  const hydrateLiveLinkCards = async () => {
    const cards = document.querySelectorAll<HTMLElement>("[data-link-card-live]:not([data-live-ready])");

    for (const card of cards) {
      card.dataset.liveReady = "true";
      if (card.dataset.auto !== "true") continue;

      const url = card.dataset.url;
      if (!url) continue;

      try {
        const response = await fetch(`/api/link-preview.json?url=${encodeURIComponent(url)}`);
        const payload = await response.json() as LinkPreviewResponse;
        const data = payload.data;
        if (!payload.ok || !data) continue;

        if (data.finalUrl) {
          const anchor = card as HTMLAnchorElement;
          anchor.href = data.finalUrl;
          const host = new URL(data.finalUrl).hostname.replace(/^www\./, "");
          const hostEl = card.querySelector<HTMLElement>("[data-card-host]");
          if (hostEl) hostEl.textContent = host;
        }

        if (card.dataset.titleLocked !== "true" && data.title) {
          const titleEl = card.querySelector<HTMLElement>("[data-card-title]");
          if (titleEl) titleEl.textContent = data.title;
        }

        if (card.dataset.descLocked !== "true" && data.desc) {
          const descEl = card.querySelector<HTMLElement>("[data-card-desc]");
          if (descEl) {
            descEl.textContent = data.desc;
            descEl.hidden = false;
          }
        }

        if (card.dataset.iconLocked !== "true" && data.icon) {
          setLiveLinkIcon(card, data.icon);
        }
      } catch {
        // Live cards are progressive enhancement; keep the server-rendered fallback.
      }
    }
  };

  hydrateLiveLinkCards();
  document.addEventListener("astro:page-load", hydrateLiveLinkCards);
</script>
